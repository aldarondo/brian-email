# Gmail account to send from
GMAIL_USER=brian@gmail.com

# Gmail App Password (NOT your regular password)
# Create at: https://myaccount.google.com/apppasswords
# Requires 2FA to be enabled on the Gmail account
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional: default "from" display name
GMAIL_FROM_NAME=Brian

# Gmail API OAuth2 — required for list_drafts tool only (not needed for send_email)
# 1. Create OAuth2 Desktop credentials at console.cloud.google.com → APIs → Gmail API
# 2. Run: node src/authorize.js   to get the refresh token interactively
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=
