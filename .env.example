# Gmail account to send from
GMAIL_USER=brian@gmail.com

# Gmail App Password (NOT your regular password)
# Create at: https://myaccount.google.com/apppasswords
# Requires 2FA to be enabled on the Gmail account
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional: default "from" display name
GMAIL_FROM_NAME=Brian

# Gmail API OAuth2 — required for list_drafts tool only (not needed for send_email)
# 1. Create OAuth2 Desktop credentials at console.cloud.google.com → APIs → Gmail API
# 2. Run: node src/authorize.js   to get the refresh token interactively
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=

# API key for the MCP SSE server (HTTP mode only — not used for stdio).
# Callers must send: Authorization: Bearer <value>
# Generate with: openssl rand -hex 32
# If unset, the server starts but logs a warning and accepts all connections.
MCP_API_KEY=

# Optional tuning
# PORT=8768                  # SSE server port (default: 8768)
# EMAIL_RATE_LIMIT_PER_HOUR=20  # max emails per hour (default: 20)
# LOG_FILE=/logs/brian-email.log  # path to log file (omit to log to stderr only)
# LOG_MAX_SIZE_MB=10         # max log file size in MB before rotation (default: 10)
# LOG_MAX_FILES=5            # number of rotated log files to keep (default: 5)
